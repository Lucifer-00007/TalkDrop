rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.isAdmin == true;
    }

    function isValidRoomCreate() {
      return request.resource.data.keys().hasOnly(['name', 'createdAt', 'createdBy']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt == request.time;
    }

    function isValidMessageCreate() {
      return request.resource.data.keys().hasOnly([
          'senderId',
          'senderName',
          'text',
          'createdAt',
          'expiresAt'
        ]) &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderName is string &&
        request.resource.data.senderName.size() > 0 &&
        request.resource.data.senderName.size() <= 80 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 1000 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.expiresAt is timestamp &&
        request.resource.data.expiresAt > request.time;
    }

    match /rooms/{roomId} {
      allow get: if isSignedIn();
      allow list, delete: if isAdmin();
      allow create: if isSignedIn() && isValidRoomCreate();
      allow update: if isAdmin();

      match /messages/{messageId} {
        allow get, list, delete: if isAdmin();
        allow create: if isSignedIn() && isValidMessageCreate();
        allow update: if isAdmin();
      }
    }
  }
}
